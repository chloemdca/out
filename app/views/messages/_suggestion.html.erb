<%# suggestion = {
  id: 1,
  name: "XXX Cafe",
  category: "cafe",
  distance: "1.3km"
} %>

<div class="
  flex
  min-h-[220px]
  min-w-[220px]
  flex-col
  justify-between
  rounded-2xl
  border
  border-gray-200
  bg-white
  p-4
  shadow-sm
">

  <div>

    <div class="mb-2">

      <h3 class="font-semibold text-gray-900">
        <%= suggestion["name"] %>
      </h3>

      <p class="text-sm text-gray-500">
        <%= suggestion["category"] %>
      </p>

    </div>

    <p class="text-sm text-gray-600">
      <%= suggestion["distance"] %> km away
    </p>

  </div>

  <div class="mt-4">

    <%# button_to(
      "Add to List",
      lists_path(
        venue_id: suggestion["id"]
      ),
      method: :post,
      class: "w-full rounded-xl bg-black px-3 py-2 text-sm font-medium text-white transition hover:bg-gray-800"
    ) %>
    <!-- Include this script tag or install `@tailwindplus/elements` via npm: -->
    <!-- <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script> -->
    <button command="show-modal" commandfor="dialog_for_message_<%= message.id%>_suggestion_<%= suggestion["id"] %>" class="w-full rounded-xl bg-black px-3 py-2 text-sm font-medium text-white transition hover:bg-gray-800">Add to List</button>
    <el-dialog>
      <dialog id="dialog_for_message_<%= message.id%>_suggestion_<%= suggestion["id"] %>" aria-labelledby="dialog-title" class="fixed inset-0 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-transparent">
        <el-dialog-backdrop class="fixed inset-0 bg-gray-500/75 transition-opacity data-closed:opacity-0 data-enter:duration-300 data-enter:ease-out data-leave:duration-200 data-leave:ease-in"></el-dialog-backdrop>

        <div tabindex="0" class="flex min-h-full items-end justify-center p-4 text-center focus:outline-none sm:items-center sm:p-0">
          <el-dialog-panel class="relative transform overflow-hidden rounded-lg bg-white px-4 pt-5 pb-4 text-left shadow-xl transition-all data-closed:translate-y-4 data-closed:opacity-0 data-enter:duration-300 data-enter:ease-out data-leave:duration-200 data-leave:ease-in sm:my-8 sm:w-full sm:max-w-sm sm:p-6 data-closed:sm:translate-y-0 data-closed:sm:scale-95">
            <%# CONTENT OF DIALOG %>
            <h2 class="text-lg font-semibold mb-4">Add to list:</h2>
            <ul class="flex flex-col gap-1">
              <% current_user.lists.each do |list| %>
                <%# suggestion["id"] is essentially the id of the suggested venue %>
                <%# SO let's check if it's in the list already %>
                <%= turbo_frame_tag "toggle_venue_#{suggestion["id"]}_for_list_#{list.id}" do %>
                  <% if list.venues.find_by(id: suggestion["id"]).present? %>
                    <li>
                      <%= link_to toggle_venue_list_path(list, venue_id: suggestion["id"]), data: { turbo_method: :post }, class: "p-4 rounded-xl flex items-center gap-2 border border-gray-900 bg-gray-50" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                          <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
                        </svg>
                        <span><%= list.name %></span>
                      <% end %>
                    </li>
                  <% else %>
                    <li>
                      <%= link_to toggle_venue_list_path(list, venue_id: suggestion["id"]), data: { turbo_method: :post }, class: "p-4 rounded-xl flex items-center gap-2 hover:bg-gray-50" do %>
                        <div class="size-6 bg-gray-200 rounded-full"></div>
                        <span><%= list.name %></span>
                      <% end %>
                    </li>
                  <% end %>
                <% end %>
              <% end %>
            </ul>
          </el-dialog-panel>
        </div>
      </dialog>
    </el-dialog>

  </div>

</div>
