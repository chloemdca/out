<div class="
  flex
  min-h-[220px]
  min-w-[220px]
  flex-col
  justify-between
  rounded-2xl
  border
  border-gray-200
  bg-white
  p-4
  shadow-sm
">

  <div>

    <div class="mb-2">

      <h3 class="font-semibold text-gray-900">
        <%= suggestion["name"] %>
      </h3>

      <p class="text-sm text-gray-500">
        <%= suggestion["category"] %>
      </p>

    </div>

    <p class="text-sm text-gray-600">
      <%= suggestion["distance"] %> km away
    </p>

  </div>

  <div class="mt-4">

    <%= button_to(
      "Add to List",
      lists_path(
        venue_id: suggestion["id"]
      ),
      method: :post,
      class: "
        w-full
        rounded-xl
        bg-black
        px-3
        py-2
        text-sm
        font-medium
        text-white
        transition
        hover:bg-gray-800
      "
    ) %>

  </div>

</div>
