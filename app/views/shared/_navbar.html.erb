<nav class="flex items-center justify-between px-4 py-2 bg-white shadow-sm">
  <%= image_tag "Logo_app_out.jpg", class: "h-10 w-auto" %>

  <div class="flex items-center gap-4">
    <% if user_signed_in? %>
      <%= link_to "Home", root_path, class: "font-medium hover:text-gray-600" %>
      <%= link_to "Chat", chats_path, class: "font-medium hover:text-gray-600" %>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "signout-btn" %>
      <%= link_to user_path(current_user) do %>
        <%= image_tag "user_image.svg", class: "h-10 w-10 rounded-full", alt: "profile" %>
      <% end %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "font-medium hover:text-gray-600" %>
    <% end %>
  </div>
</nav>
