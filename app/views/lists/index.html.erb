<div class="mx-auto max-w-7xl px-6 mt-6">
  <div class="flex justify-between">
    <%= link_to "BACK TO HOME",
        root_path,
        class: "inline-flex items-center rounded-md bg-gray-200 px-4 py-2 text-gray-800 hover:bg-gray-300 transition",
        style: "font-family: 'Londrina Solid', sans-serif;"
        %>
    <%= link_to "GO TO VENUES",
        venues_path,
        class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-500 transition",
        style: "font-family: 'Londrina Solid', sans-serif;"
        %>
  </div>

  <div class="mt-8 text-center">
    <h1 style="font-family: 'Londrina Solid', sans-serif; font-size: 2.5rem; text-transform: uppercase;">
      Your Lists
    </h1>
    <p class="mt-2" style="font-family: 'Londrina Solid', sans-serif; font-size: 1.2rem; color: #4b5563;">
      View, create and share your lists
    </p>
  </div>

  <div class="mt-10 flex justify-center">
    <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      <% @lists.each do |list| %>
        <li class="h-[260px] w-[260px]">
          <div class="group h-full w-full rounded-xl bg-white shadow-sm hover:shadow-xl transition">
            <div class="flex h-full flex-col justify-between p-6 text-center">

              <%= link_to list_path(list), class: "flex flex-col items-center" do %>
                <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full text-3xl">
                  <%= list.emoji_default %>
                </div>
                <h2 class="mt-2 text-lg font-semibold text-gray-900 line-clamp-2">
                  <%= list.name %>
                </h2>
                <div class="mt-2 text-sm text-gray-500 space-y-1">
                  <div>📍 <%= list.venues.size %></div>
                  <div>⏱ <%= time_ago_in_words(list.updated_at) %> ago</div>
                </div>
              <% end %>
              <button class="mt-8 inline-flex text-center items-center justify-between bg-green-300 rounded-md p-6 py-2 hover:bg-green-500 transition",
                      style="font-family: 'Londrina Solid', sans-serif;">
                Share with friends
                <i class="fa-regular fa-paper-plane"></i>
              </button>
            </div>
          </div>
        </li>
      <% end %>
      <li class="h-[260px] w-[260px]">
        <div class="group h-full w-full rounded-xl border-2 border-dashed border-gray-300
                    bg-white shadow-sm hover:shadow-xl hover:border-indigo-600
                    hover:bg-indigo-50 transition">
          <div class="flex h-full flex-col justify-center items-center p-6 text-center">
            <%= link_to "Create a new list", new_list_path,
                class: "text-lg font-semibold text-gray-900 group-hover:text-indigo-600" %>
            <div class="flex h-14 w-14 items-center justify-center rounded-full
                  bg-gray-100 text-gray-500 text-2xl
                  group-hover:bg-indigo-100 group-hover:text-indigo-600
                  transition mt-4">
              <i class="fa-solid fa-plus"></i>
            </div>
          </div>
        </div>
      </li>
    </ul>
  </div>
</div>
