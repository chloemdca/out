<h1 class="mb-4">Your Lists</h1>

<div class="grid grid-cols-3 gap-6 size-full">
  <% @lists.each do |list| %>
    <%= link_to list_path(list),
      class: "block bg-white rounded-xl shadow-md hover:shadow-xl transition overflow-hidden" do %>
      <div class="p-6">
        <h3 class="text-sm font-semibold text-gray-900">
          <%= list.name %>
        </h3>
      </div>
    <% end %>
  <% end %>
</div>
