<div class="mt-5 shadow-sm rounded-lg p-4">
  <%= simple_form_for (@list) do |f| %>
    <div class="space-y-12">
        <div class="sm:col-span-4">
            <%= f.label :name, class: "block text-sm/6 font-medium text-gray-900" %>
            <div class="mt-2">
              <div class="flex items-center rounded-md bg-white pl-3
                          outline outline-1 -outline-offset-1 outline-gray-300
                          focus-within:outline-2 focus-within:-outline-offset-2
                          focus-within:outline-indigo-600">

                <%= f.input_field :name,
                  placeholder: "Recommended venues",
                  class: "block min-w-0 grow bg-white py-1.5 pr-3 pl-1
                          text-base text-gray-900 placeholder:text-gray-400
                          focus:outline-none sm:text-sm/6" %>
              </div>
            </div>
          </div>

          <div class="col-span-full">
            <%= f.input :comment, class: "block text-sm/6 font-medium text-gray-900" %>
            <p class="mt-3 text-sm/6 text-gray-600">Add a short description about this list.</p>
          </div>
          <div>
            <%= f.submit "Create a new list",
              class: "rounded-md bg-black px-4 py-2 text-sm font-semibold text-white
                      hover:bg-gray-800 focus-visible:outline focus-visible:outline-2
                      focus-visible:outline-offset-2 focus-visible:outline-black cursor-pointer" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>


<div class="col-span-full">
  <%= f.label :comment, class: "block text-sm/6 font-medium text-gray-900" %>

  <div class="mt-2">
    <%= f.input_field :comment,
      as: :text,
      rows: 3,
      class: "block w-full rounded-md bg-white px-3 py-1.5
              text-base text-gray-900 placeholder:text-gray-400
              outline outline-1 -outline-offset-1 outline-gray-300
              focus:outline-2 focus:-outline-offset-2
              focus:outline-indigo-600 sm:text-sm/6" %>
  </div>

  <p class="mt-3 text-sm/6 text-gray-600">
    Add a short description for this list.
  </p>
</div>
