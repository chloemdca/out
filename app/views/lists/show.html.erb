<div class="mx-auto max-w-7xl px-6 mt-6">
  <div class="flex justify-between">
    <%= link_to "Back to list",
        lists_path,
        class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-white font-semibold hover:bg-red-800 transition" %>
    <%= link_to "To venues",
        venues_path,
        class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-white font-semibold hover:bg-red-800 transition" %>
  </div>

  <div class="mt-6 text-center">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-white shadow text-3xl">
      <%= @list.emoji_default %>
    </div>
    <h1 class="mt-4 text-3xl font-bold text-gray-900">
      <%= @list.name %>
    </h1>
    <% if @list.comment.present? %>
      <p class="mt-2 text-gray-600">
        <%= @list.comment %>
      </p>
    <% end %>
  </div>
  <div class="mt-10 flex justify-center">
    <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">

      <% @list.venues.each do |venue| %>
        <li class="h-[200px] w-[260px]">
          <div class="group h-full w-full rounded-xl bg-white shadow-sm hover:shadow-xl transition">
            <div class="flex h-full flex-col justify-between p-6 text-center">
              <div>
                <h2 class="text-lg font-semibold text-gray-900 line-clamp-2">
                  <%= venue.name %>
                </h2>
                <p class="mt-2 text-sm text-gray-500">
                  <%= venue.category %>
                </p>
              </div>
              <span class="mx-auto inline-flex items-center rounded-full bg-green-50 px-3 py-1 text-xs font-medium text-green-700">
                Type
              </span>
            </div>
          </div>
        </li>
      <% end %>
      <li class="h-[200px] w-[260px]">
        <div class="group h-full w-full rounded-xl border-2 border-dashed border-gray-300
                    bg-white shadow-sm hover:shadow-xl hover:border-indigo-600
                    hover:bg-indigo-50 transition">
          <div class="flex h-full flex-col justify-center items-center p-6 text-center">
            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-indigo-600">Add a venue</h3>
            <%= render "lists/venue_dialog", list: @list %>
            <i class="fa-solid fa-plus mt-4"></i>
          </div>
        </div>
      </li>
    </ul>
  </div>
</div>
