<div class="max-w-lg mx-auto mt-10">
  <div class="bg-white rounded-lg shadow p-6">
    <h1 class="text-2xl font-bold mb-4" style="font-family: 'Londrina Solid', sans-serif; text-transform: uppercase; color: #C12743;"><%= @log.venue.name %></h1>
    <p class="mt-3">
      <strong>Date Visited:</strong>
      <%= @log.date_visited&.strftime("%B %d, %Y") %>
    </p>
    <p class="mt-2">
      <strong>Rating:</strong>
      <%= @log.rating %>/5
    </p>
    <p class="mt-2">
      <strong>Comment:</strong>
      <%= @log.comment %>
    </p>
    <div class="flex gap-3 mt-4 justify-end">
      <%= link_to "EDIT", edit_log_path(@log), class: "inline-block mt-4 px-4 py-2 text-white rounded", style: "font-family: 'Londrina Solid', sans-serif; background-color: #757575;" %>
      <%= link_to "DELETE", log_path(@log), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "inline-block mt-4 px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700", style: "font-family: 'Londrina Solid', sans-serif;" %>
    </div>
  </div>
  <%= link_to "BACK", logs_path, class: "inline-block mt-4 px-4 py-2 bg-gray-200 rounded hover:bg-gray-300", style: "font-family: 'Londrina Solid', sans-serif;" %>
</div>
