<div class="max-w-lg mx-auto mt-10">
  <div class="bg-white rounded-lg shadow p-6">
    <h1 class="text-2xl font-bold mb-4"><%= @log.venue.name %></h1>
    <p class="mt-3">
      <strong>Rating:</strong>
      <%= @log.rating %>/5
    </p>
    <p class="mt-2">
      <strong>Comment:</strong>
      <%= @log.comment %>
    </p>
  <div class="flex gap-3 mt-4">
    <%= link_to "Edit", edit_log_path(@log), class: "inline-block mt-4 px-4 py-2 bg-yellow-400 rounded hover:bg-yellow-500" %>
    <%= link_to "Delete", log_path(@log), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "inline-block mt-4 px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" %>
  </div>
</div>
<%= link_to "Back", logs_path, class: "inline-block mt-4 px-4 py-2 bg-gray-200 rounded hover:bg-gray-300" %>
