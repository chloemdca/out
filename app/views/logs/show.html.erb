<div class="container mt-5">
  <div class="card p-4">
    <h1><%= @log.venue.name %></h1>
    <p class="mt-3">
      <strong>Rating:</strong>
      <%= @log.rating %>/5
    </p>
    <p>
      <strong>Comment:</strong>
      <%= @log.comment %>
    </p>
    <p class="text-muted">
      Posted by <%= @log.user.user_alias %>
    </p>
    <%= link_to "Back to logs",
        logs_path,
        class: "btn btn-secondary mt-3" %>
  </div>

  <div class="mt-4">
    <%= link_to "Edit",
       edit_log_path(@log),
       class: "btn btn-warning" %>
    <%= link_to "Delete",
        log_path(@log),
        data: { turbo_method: :delete,
                turbo_confirm: "Are you sure?" },
        class: "btn btn-danger" %>
  </div>
</div>
