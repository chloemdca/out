<div class="container mt-5">
  <h1>Create a log</h1>
  <%= form_with model: [@venue, @log] do |f| %>
    <div class="mb-3">
      <%= f.label :rating %>
      <%= f.number_field :rating,
          class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= f.label :comment %>
      <%= f.text_area :comment,
          class: "form-control" %>
    </div>
    <%= f.submit "Create log",
        class: "btn btn-primary" %>
  <% end %>
</div>
