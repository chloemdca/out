<div class="flex flex-col max-w-sm">
  <h2 class="text-2xl font-bold mb-4">Log in</h2>

  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="flex flex-col gap-3">
      <%= f.input :email,
                  required: false,
                  autofocus: true,
                  input_html: { autocomplete: "email", class: "w-full border rounded px-3 py-2" } %>
      <%= f.input :password,
                  required: false,
                  input_html: { autocomplete: "current-password", class: "w-full border rounded px-3 py-2" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
    </div>

    <div class="mt-4">
      <%= f.button :submit, "Log in", class: "px-4 py-2 bg-black text-white rounded hover:bg-gray-800" %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= render "devise/shared/links" %>
  </div>
</div>
