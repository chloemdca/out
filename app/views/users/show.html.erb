<div class="max-w-2xl mx-auto mt-10">
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex items-center gap-4 mb-4">
      <%= image_tag "user_image.svg", class: "h-16 w-16 rounded-full" %>
      <div>
        <h1 class="text-2xl font-bold"><%= @user.user_alias %></h1>
        <p class="text-gray-500"><%= @user.email %></p>
        <p class="text-gray-500"><%= @user.first_name %> <%= @user.last_name %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-xl font-bold mb-4">My Logs</h2>
    <% if @user.logs.any? %>
      <% @user.logs.each do |log| %>
        <div class="border-b py-3">
          <p class="font-semibold"><%= log.venue.name %></p>
          <p class="text-gray-500">Rating: <%= log.rating %>/5</p>
          <p class="text-gray-500"><%= log.comment %></p>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500">No logs yet.</p>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-xl font-bold mb-4">My Lists</h2>
    <% if @user.lists.any? %>
      <% @user.lists.each do |list| %>
        <div class="border-b py-3">
          <p class="font-semibold"><%= list.name %></p>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500">No lists yet.</p>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-xl font-bold mb-4">My Venues</h2>
    <% if @user.venues.any? %>
      <% @user.venues.each do |venue| %>
        <div class="border-b py-3">
          <p class="font-semibold"><%= venue.name %></p>
          <p class="text-gray-500"><%= venue.category %></p>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500">No venues yet.</p>
    <% end %>
  </div>
</div>
