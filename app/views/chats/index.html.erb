<div class="container mt-5">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold">
      My Chats
    </h1>
    <%= button_to(
      "New Chat",
      chats_path,
      method: :post,
      class: "
        rounded-xl
        bg-black
        px-4
        py-2
        text-white
        font-medium
        hover:bg-gray-800
        transition
      "
    ) %>
  </div>

  <% @chats.each do |chat| %>
    <%= link_to chat_path(chat), class: "text-decoration-none" do %>
      <div class="card mb-3 p-3">
        <h5><%= chat.title %></h5>
        <p class="text-muted mb-0"><%= chat.chat_date %></p>
      </div>
    <% end %>
  <% end %>
</div>
