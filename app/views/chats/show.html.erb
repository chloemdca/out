<div class="container mt-5">
  <h1>Chat</h1>

  <div class="chat-messages space-y-4">
    <% @chat.messages.each do |message| %>
      <div class="message-row flex <%= message.role == "user" ? "justify-end" : "justify-start" %>">
        <div class="max-w-xl">
          <div class="
            rounded-2xl
            px-4
            py-3
            shadow-sm
            <%= message.role == "user" ? "bg-blue-500 text-white" : "bg-gray-100 text-gray-900" %>
          ">
            <p>
              <%= message.content %>
            </p>
          </div>
          <% if message.role == "assistant" %>
            <% suggestions = message.metadata&.dig("suggestions") || [] %>
            <% if suggestions.any? %>
              <div class="mt-3 flex gap-3 overflow-x-auto pb-2">
                <% suggestions.each do |suggestion| %>
                  <%= render "messages/suggestion", suggestion: suggestion %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%= form_with model: [@chat, @message] do |f| %>
    <p><%= @message.errors.full_messages.join(" | ") %></p>
    <div class="mb-6">
      <%= f.text_area :content, class: "form-control" %>
    </div>
    <%= f.submit "Send", class: "btn btn-primary" %>
  <% end %>
</div>
